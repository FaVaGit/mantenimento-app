# Port on which the backend server listens (default: 3000)
PORT=3000

# Optional: enable minimized structured access logging (defaults to true in production)
ACCESS_LOG_ENABLED=true

# Optional: salt used to anonymize client IPs in access logs
ACCESS_LOG_SALT=change-me

# Optional: in-memory rate limiting for POST /api/calculate
CALCULATE_RATE_WINDOW_MS=60000
CALCULATE_RATE_MAX_REQUESTS=30

# Optional: CLI donor admin script (scripts/manage-donor-users.mjs)
# Use service-role key only in trusted local environments.
DONOR_ADMIN_SUPABASE_URL=
DONOR_ADMIN_SUPABASE_SERVICE_ROLE_KEY=
