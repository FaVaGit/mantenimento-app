# Development environment — used by: npm run dev
# This file is intentionally committed so it works out of the box.

# Dev server port (separate from production so both can run simultaneously)
PORT=3001

NODE_ENV=development

# Serve raw app.js (without minification) — no rebuild needed after edits
DEV_SOURCE_JS=true

# Disable access logging in dev to reduce noise
ACCESS_LOG_ENABLED=false

# Loose rate limit for local testing
CALCULATE_RATE_WINDOW_MS=60000
CALCULATE_RATE_MAX_REQUESTS=200
