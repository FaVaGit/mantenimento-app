# Node runtime
NODE_ENV=production
PORT=3000
HTTP_PORT=80
HTTPS_PORT=443
TLS_CERTS_DIR=./certs

# Minimal privacy-preserving access logging
ACCESS_LOG_ENABLED=true
ACCESS_LOG_SALT=replace-with-a-random-secret-value

# API protection
CALCULATE_RATE_WINDOW_MS=60000
CALCULATE_RATE_MAX_REQUESTS=30

# Secure URL login (one-time signed token exchange)
AUTH_URL_LOGIN_SECRET=replace-with-very-long-random-secret
AUTH_URL_LOGIN_ALLOWED_USER=favagit,fabio.vacchino
AUTH_URL_LOGIN_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
AUTH_URL_LOGIN_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
AUTH_URL_LOGIN_SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
AUTH_URL_LOGIN_SUPABASE_EMAIL=favagit@example.com
AUTH_URL_LOGIN_SUPABASE_PASSWORD=replace-with-strong-password
AUTH_URL_LOGIN_SUPABASE_USERS_JSON={"favagit":{"password":"replace-favagit-pass"},"fabio.vacchino":{"password":"replace-fabio-pass"}}
AUTH_URL_LOGIN_MAX_TTL_SEC=180
AUTH_URL_LOGIN_BOOTSTRAP_KEY=replace-with-long-random-bootstrap-key
AUTH_URL_LOGIN_FRONTEND_BASE=https://favagit.github.io/mantenimento-app/autologin.html

# CORS allowlist for browser->API calls (comma-separated)
API_ALLOWED_ORIGINS=https://favagit.github.io